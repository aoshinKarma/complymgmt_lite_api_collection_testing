example {
  name: GET_COCKPIT_COMPLIANCE_PORTFOLIO(latest)
  
  request: {
    url: {{PROTO}}{{HOST}}:{{PORT}}/api/{{VERSION}}/dashboard/view/compliance/cockpit/portfolio?page=1&limit=20
    method: GET
    mode: none
    params:query: {
      page: 1
      limit: 20
    }
  
    headers: {
      Referer: https://complymgmt.ai
    }
  }
  
